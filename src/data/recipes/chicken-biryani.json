  "instructions": [
    {
      "step": 1,
      "title": {
        "en": "Prepare the Rice",
        "bn": "চাল প্রস্তুত করুন"
      },
      "description": {
        "en": "Wash the basmati rice thoroughly and soak it for 30 minutes.",
        "bn": "বাসমতি চাল ভালোভাবে ধুয়ে ৩০ মিনিট ভিজিয়ে রাখুন।"
      },
      "tip": {
        "en": "Soaking helps the rice cook evenly and stay fluffy.",
        "bn": "চাল ভিজিয়ে রাখলে সমানভাবে সেদ্ধ হয় এবং ঝরঝরে থাকে।"
      }
    },
    {
      "step": 2,
      "title": {
        "en": "Marinate the Chicken",
        "bn": "মুরগি মেরিনেট করুন"
      },
      "description": {
        "en": "Mix the chicken with yogurt, ginger garlic paste, lemon juice, turmeric, chili powder, garam masala, and salt. Marinate for at least 30 minutes.",
        "bn": "মুরগির সাথে টক দই, আদা-রসুন বাটা, লেবুর রস, হলুদ, মরিচের গুঁড়া, গরম মসলা ও লবণ মিশিয়ে কমপক্ষে ৩০ মিনিট মেরিনেট করুন।"
      },
      "tip": {
        "en": "For deeper flavor, marinate overnight.",
        "bn": "আরও ভালো স্বাদের জন্য সারা রাত মেরিনেট করে রাখতে পারেন।"
      }
    },
    {
      "step": 3,
      "title": {
        "en": "Cook the Rice",
        "bn": "চাল সেদ্ধ করুন"
      },
      "description": {
        "en": "Boil the rice with whole spices until it is about 70% cooked. Drain and set aside.",
        "bn": "গোটা মসলার সাথে চাল ৭০% সেদ্ধ হওয়া পর্যন্ত রান্না করুন। তারপর পানি ঝরিয়ে আলাদা রাখুন।"
      }
    },
    {
      "step": 4,
      "title": {
        "en": "Cook the Chicken",
        "bn": "মুরগি রান্না করুন"
      },
      "description": {
        "en": "Cook the marinated chicken with onions and tomatoes until the chicken is tender.",
        "bn": "মেরিনেট করা মুরগি পেঁয়াজ ও টমেটোর সাথে নরম হওয়া পর্যন্ত রান্না করুন।"
      }
    },
    {
      "step": 5,
      "title": {
        "en": "Layer the Biryani",
        "bn": "বিরিয়ানির স্তর তৈরি করুন"
      },
      "description": {
        "en": "Layer the chicken and rice in a heavy pot. Add fried onions, mint, coriander, saffron milk, and ghee between layers.",
        "bn": "ভারী পাত্রে মুরগি ও চাল স্তরে স্তরে সাজিয়ে প্রতিটি স্তরের মাঝে ভাজা পেঁয়াজ, পুদিনা, ধনেপাতা, জাফরান দুধ ও ঘি দিন।"
      }
    },
    {
      "step": 6,
      "title": {
        "en": "Dum Cooking",
        "bn": "দমে রান্না করুন"
      },
      "description": {
        "en": "Cover tightly and cook over low heat for 20–25 minutes.",
        "bn": "ভালোভাবে ঢেকে কম আঁচে ২০–২৫ মিনিট দমে রান্না করুন।"
      }
    },
    {
      "step": 7,
      "title": {
        "en": "Serve",
        "bn": "পরিবেশন করুন"
      },
      "description": {
        "en": "Gently fluff the biryani and serve hot with raita or salad.",
        "bn": "হালকাভাবে বিরিয়ানি নেড়ে রায়তা বা সালাদের সাথে গরম গরম পরিবেশন করুন।"
      }
    }
  ],

  "tips": [
    {
      "en": "Use aged basmati rice for the best texture.",
      "bn": "সেরা টেক্সচারের জন্য পুরনো বাসমতি চাল ব্যবহার করুন।"
    },
    {
      "en": "Do not overcook the rice before layering.",
      "bn": "স্তর তৈরির আগে চাল বেশি সেদ্ধ করবেন না।"
    },
    {
      "en": "Cook on low heat to achieve authentic dum biryani.",
      "bn": "আসল দম বিরিয়ানির স্বাদের জন্য কম আঁচে রান্না করুন।"
    }
  ],

