  "instructions": [
    {
      "step": 1,
      "title": "Prepare the Rice",
      "description": "Wash the basmati rice thoroughly and soak it for 30 minutes.",
      "tip": "Soaking helps the rice cook evenly and stay fluffy."
    },
    {
      "step": 2,
      "title": "Marinate the Chicken",
      "description": "Mix the chicken with yogurt, ginger garlic paste, lemon juice, turmeric, chili powder, garam masala, and salt. Marinate for at least 30 minutes.",
      "tip": "For deeper flavor, marinate overnight."
    },
    {
      "step": 3,
      "title": "Cook the Rice",
      "description": "Boil the rice with whole spices until it is about 70% cooked. Drain and set aside."
    },
    {
      "step": 4,
      "title": "Cook the Chicken",
      "description": "Cook the marinated chicken with onions and tomatoes until the chicken is tender."
    },
    {
      "step": 5,
      "title": "Layer the Biryani",
      "description": "Layer the chicken and rice in a heavy pot. Add fried onions, mint, coriander, saffron milk, and ghee between layers."
    },
    {
      "step": 6,
      "title": "Dum Cooking",
      "description": "Cover tightly and cook over low heat for 20–25 minutes."
    },
    {
      "step": 7,
      "title": "Serve",
      "description": "Gently fluff the biryani and serve hot with raita or salad."
    }
  ],

