  "instructions": [
    {
      "step": 1,
      "title": {
        "en": "Prepare the Vegetables",
        "bn": "সবজি প্রস্তুত করুন"
      },
      "description": {
        "en": "Wash all vegetables thoroughly. Chop the lettuce, slice the cucumber and onion, dice the tomatoes, and grate the carrot.",
        "bn": "সবজি ভালোভাবে ধুয়ে নিন। লেটুস কুচি করুন, শসা ও পেঁয়াজ পাতলা করে কাটুন, টমেটো ছোট টুকরো করুন এবং গাজর কুঁচি করুন।"
      }
    },
    {
      "step": 2,
      "title": {
        "en": "Combine the Vegetables",
        "bn": "সবজি একসাথে মেশান"
      },
      "description": {
        "en": "Place all the prepared vegetables into a large mixing bowl.",
        "bn": "সব প্রস্তুত করা সবজি একটি বড় মিক্সিং বাউলে নিন।"
      }
    },
    {
      "step": 3,
      "title": {
        "en": "Prepare the Dressing",
        "bn": "ড্রেসিং তৈরি করুন"
      },
      "description": {
        "en": "Whisk together olive oil, lemon juice, salt, and black pepper until well combined.",
        "bn": "অলিভ অয়েল, লেবুর রস, লবণ এবং গোলমরিচ একসাথে ভালোভাবে ফেটিয়ে ড্রেসিং তৈরি করুন।"
      }
    },
    {
      "step": 4,
      "title": {
        "en": "Mix the Salad",
        "bn": "সালাদ মেশান"
      },
      "description": {
        "en": "Pour the dressing over the vegetables and toss gently until everything is evenly coated.",
        "bn": "সবজির উপর ড্রেসিং ঢেলে আলতোভাবে মিশিয়ে নিন যাতে সবজিগুলো সমানভাবে কোট হয়।"
      }
    },
    {
      "step": 5,
      "title": {
        "en": "Serve",
        "bn": "পরিবেশন করুন"
      },
      "description": {
        "en": "Serve immediately while the vegetables are fresh and crisp.",
        "bn": "সবজি সতেজ ও মচমচে থাকা অবস্থায় সঙ্গে সঙ্গে পরিবেশন করুন।"
      }
    }
  ],

  "tips": [
    {
      "en": "Chill the vegetables before serving for extra freshness.",
      "bn": "আরও সতেজ স্বাদের জন্য পরিবেশনের আগে সবজি ঠান্ডা করে নিন।"
    },
    {
      "en": "Add feta cheese or avocado for extra flavor and nutrition.",
      "bn": "অতিরিক্ত স্বাদ ও পুষ্টির জন্য ফেটা চিজ বা অ্যাভোকাডো যোগ করতে পারেন।"
    },
    {
      "en": "Prepare the dressing separately and mix just before serving.",
      "bn": "ড্রেসিং আলাদা তৈরি করে পরিবেশনের ঠিক আগে সালাদের সাথে মেশান।"
    }
  ],

